{% comment %}
  Live motion-graphics hero. Renders a Remotion composition in the browser via
  @remotion/player (bundled into assets/oni-motion.js as the <oni-motion> element)
  and overlays the brand headline + CTAs as accessible HTML. Falls back to an
  animated CSS backdrop when JS is unavailable or the visitor prefers reduced motion.
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="oni-motion-hero section section--full-width color-{{ section.settings.color_scheme }}"
  style="--oni-motion-min-h: {{ section.settings.min_height }}svh;"
  data-testid="oni-motion-hero-{{ section.id }}"
>
  <oni-motion
    class="oni-motion-hero__bg"
    data-kanji="{{ section.settings.kanji | escape }}"
    aria-hidden="true"
  >
    <div class="oni-motion-hero__fallback" aria-hidden="true">
      <span class="oni-motion-hero__fallback-kanji">{{ section.settings.kanji }}</span>
    </div>
  </oni-motion>

  <div class="oni-motion-hero__scrim" aria-hidden="true"></div>

  <div class="oni-motion-hero__content">
    {% if section.settings.kicker != blank %}
      <p class="oni-motion-hero__kicker">{{ section.settings.kicker }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="oni-motion-hero__title" data-text="{{ section.settings.heading | escape }}">
        {{ section.settings.heading | escape }}
      </h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="oni-motion-hero__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="oni-motion-hero__actions">
      {% if section.settings.button_label_1 != blank and section.settings.button_link_1 != blank %}
        <a href="{{ section.settings.button_link_1 }}" class="button">
          {{- section.settings.button_label_1 -}}
        </a>
      {% endif %}
      {% if section.settings.button_label_2 != blank and section.settings.button_link_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="button button-secondary">
          {{- section.settings.button_label_2 -}}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<script src="{{ 'oni-motion.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% stylesheet %}
  .oni-motion-hero {
    position: relative;
    display: grid;
    place-items: center;
    min-height: var(--oni-motion-min-h, 90svh);
    overflow: hidden;
    isolation: isolate;
    text-align: center;
  }

  .oni-motion-hero__bg {
    position: absolute;
    z-index: 0;
    inset: 0;
    display: block;
    background: var(--color-background);
  }

  /* CSS fallback backdrop (visible until the player mounts, and for reduced motion) */
  .oni-motion-hero__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(38% 46% at 22% 80%, rgb(var(--color-primary-rgb) / 0.28), transparent 70%),
      radial-gradient(34% 40% at 82% 16%, rgb(0 245 255 / 0.14), transparent 70%),
      radial-gradient(55% 60% at 60% 95%, rgb(140 70 220 / 0.24), transparent 72%),
      var(--color-background);
  }

  .oni-motion-hero__fallback-kanji {
    font-family: var(--font-heading--family);
    font-size: 62vmin;
    line-height: 1;
    color: rgb(var(--color-primary-rgb) / 0.07);
    -webkit-text-stroke: 1px rgb(var(--color-primary-rgb) / 0.16);
    user-select: none;
  }

  .oni-motion-hero__scrim {
    position: absolute;
    z-index: 2;
    inset: 0;
    background: linear-gradient(
      to top,
      rgb(var(--color-background-rgb) / 0.85) 0%,
      rgb(var(--color-background-rgb) / 0.15) 45%,
      rgb(var(--color-background-rgb) / 0.55) 100%
    );
    pointer-events: none;
  }

  .oni-motion-hero__content {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 4rem 1.5rem;
    max-width: 70rem;
  }

  .oni-motion-hero__kicker {
    margin: 0;
    font-family: var(--font-accent--family);
    font-size: clamp(0.7rem, 1.4vw, 0.9rem);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-rgb) / 0.95);
  }

  .oni-motion-hero__title {
    position: relative;
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(3.5rem, 13vw, 10rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
  }

  .oni-motion-hero__sub {
    margin: 0;
    max-width: 38rem;
    font-family: var(--font-accent--family);
    font-size: clamp(0.85rem, 1.6vw, 1.05rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.78);
  }

  .oni-motion-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .oni-motion-hero__fallback {
      animation: oni-mh-haze 18s ease-in-out infinite alternate;
    }

    .oni-motion-hero__title::before,
    .oni-motion-hero__title::after {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      overflow: hidden;
      opacity: 0.85;
      pointer-events: none;
    }

    .oni-motion-hero__title::before {
      color: rgb(var(--color-primary-rgb) / 0.9);
      animation: oni-mh-glitch-a 3.4s steps(1, jump-none) infinite;
    }

    .oni-motion-hero__title::after {
      color: rgb(0 245 255 / 0.55);
      animation: oni-mh-glitch-b 2.9s steps(1, jump-none) infinite;
    }
  }

  @keyframes oni-mh-haze {
    from { transform: translate3d(-2%, -1%, 0) scale(1); }
    to   { transform: translate3d(2%, 1%, 0) scale(1.06); }
  }

  @keyframes oni-mh-glitch-a {
    0%, 91%, 100% { clip-path: inset(100% 0 0 0); transform: none; }
    92% { clip-path: inset(12% 0 78% 0); transform: translate(-0.35rem, 0); }
    94% { clip-path: inset(64% 0 22% 0); transform: translate(0.3rem, 0); }
    96% { clip-path: inset(38% 0 48% 0); transform: translate(-0.2rem, 0.05em); }
    98% { clip-path: inset(80% 0 6% 0); transform: translate(0.25rem, 0); }
  }

  @keyframes oni-mh-glitch-b {
    0%, 88%, 100% { clip-path: inset(100% 0 0 0); transform: none; }
    89% { clip-path: inset(70% 0 18% 0); transform: translate(0.4rem, 0); }
    92% { clip-path: inset(8% 0 84% 0); transform: translate(-0.3rem, 0); }
    95% { clip-path: inset(45% 0 40% 0); transform: translate(0.2rem, -0.04em); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Oni motion hero",
  "settings": [
    {
      "type": "paragraph",
      "content": "Live in-browser motion-graphics hero rendered with Remotion. Falls back to an animated backdrop when JavaScript is off or reduced motion is requested."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "新着 — Tokyo Midnight Division"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Oni Theory"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Anime streetwear forged after dark. Heavyweight hoodies & graphic tees, summoned in limited runs."
    },
    {
      "type": "text",
      "id": "kanji",
      "label": "Kanji (animated backdrop)",
      "default": "鬼"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Shop hoodies"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Shop tees"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "svh",
      "default": 90
    }
  ],
  "presets": [
    {
      "name": "Oni motion hero",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
